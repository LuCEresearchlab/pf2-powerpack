{
  "name": "pf2-powerpack",
  "displayName": "PF2 PowerPack",
  "description": "Extension for the PF2 course at USI Lugano",
  "icon": "assets/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/LuceResearchLab/pf2-extension.git"
  },
  "publisher": "luceresearchlab",
  "maintainers": [
    {
      "name": "Joey Bevilacqua",
      "email": "bevilj@usi.ch"
    }
  ],
  "version": "1.0.2",
  "engines": {
    "vscode": "^1.100.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "Java"
  ],
  "bugs": {
    "url": "https://github.com/LuceResearchLab/pf2-powerpack/issues"
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "pf2-powerpack:cmd-gradle-assemble-open-term",
        "title": "Assemble & Open new JShell session",
        "icon": "$(coffee)"
      }
    ],
    "menus": {
      "editor/title/run": [
        {
          "when": "editorLangId == java",
          "command": "pf2-powerpack:cmd-gradle-assemble-open-term",
          "group": "navigation"
        }
      ]
    },
    "themes": [
      {
        "label": "PF2 Light",
        "uiTheme": "vs",
        "path": "./themes/pf2-light.json"
      },
      {
        "label": "PF2 Dark",
        "uiTheme": "vs-dark",
        "path": "./themes/pf2-dark.json"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/node": "20.x",
    "@types/vscode": "^1.100.0",
    "@typescript-eslint/eslint-plugin": "^8.47.0",
    "@typescript-eslint/parser": "^8.47.0",
    "@vscode/vsce": "^3.7.1",
    "eslint": "^9.39.1",
    "typescript": "^5.9.3"
  }
}
